+def get_gptoss_inference_mem_requirement(
+    config: GptOssConfig,
+    prefill_or_decode: str = "decode",
+    weight_bytes_per_element: int = BYTES_FP16,
+    activation_bytes_per_element: int = BYTES_FP16,
